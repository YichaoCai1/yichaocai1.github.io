<div class="news">
  {% if site.news != blank %}
    {% assign current_lang = page.lang | default: site.lang | default: 'en' %}
    {% assign current_is_zh = false %}
    {% if current_lang == 'zh' or current_lang == 'zh-CN' or current_lang == 'cn' %}
      {% assign current_is_zh = true %}
    {% endif %}
    {% assign news_size = site.news | size %}
    <div
      class="table-responsive"
      {% if include.limit and page.announcements.scrollable and news_size > 3 %}
        style="max-height: 240px"
      {% endif %}
    >
      <table class="table table-sm table-borderless">
        {% assign news = site.news | reverse %}
        {% if include.limit and page.announcements.limit %}
          {% assign news_limit = page.announcements.limit %}
        {% else %}
          {% assign news_limit = news_size %}
        {% endif %}
        {% for item in news limit: news_limit %}
          <tr>
            <th scope="row" style="width: 20%">
              {% if current_is_zh %}
                {{ item.date | date: '%Y年%m月%d日' }}
              {% else %}
                {{ item.date | date: '%b %d, %Y' }}
              {% endif %}
            </th>
            <td>
              {% if item.inline %}
                {% if current_is_zh and item.content_zh %}
                  {{ item.content_zh | markdownify | remove: '<p>' | remove: '</p>' | emojify }}
                {% else %}
                  {{ item.content | remove: '<p>' | remove: '</p>' | emojify }}
                {% endif %}
              {% else %}
                {% assign news_title = item.title %}
                {% if current_is_zh and item.title_zh %}
                  {% assign news_title = item.title_zh %}
                {% endif %}
                <a class="news-title" href="{{ item.url | relative_url }}">{{ news_title }}</a>
              {% endif %}
            </td>
          </tr>
        {% endfor %}
      </table>
    </div>
  {% else %}
    <p>No news so far...</p>
  {% endif %}
</div>
