<header>
  {% assign current_lang = page.lang | default: site.lang | default: 'en' %}
  {% assign current_is_zh = false %}
  {% if current_lang == 'zh' or current_lang == 'zh-CN' or current_lang == 'cn' %}
    {% assign current_is_zh = true %}
  {% endif %}
  {% assign cv_pdf = site.data.socials.cv_pdf | default: '/assets/pdf/yichaocai_cv.pdf' %}
  <!-- Nav Bar -->
  <nav id="navbar" class="navbar navbar-light navbar-expand-sm {% if site.navbar_fixed %}fixed-top{% else %}sticky-top{% endif %}" role="navigation">
    <div class="container">
      <!-- Social icons on the left of the nav bar (shown on all pages) -->
      <div class="navbar-brand social">
        {% if site.data.socials.email %}
          <a href="mailto:{{ site.data.socials.email | encode_email }}" title="Email"><i class="fa-solid fa-envelope"></i></a>
        {% endif %}
        {% if site.data.socials.scholar_userid %}
          <a
            href="https://scholar.google.com/citations?user={{ site.data.socials.scholar_userid }}"
            title="Google Scholar"
            rel="external nofollow noopener"
            target="_blank"
            ><i class="ai ai-google-scholar"></i
          ></a>
        {% endif %}
        {% if site.data.socials.github_username %}
          <a href="https://github.com/{{ site.data.socials.github_username }}" title="GitHub" rel="external nofollow noopener" target="_blank"
            ><i class="fa-brands fa-github"></i
          ></a>
        {% endif %}
        {% if site.data.socials.linkedin_username %}
          <a
            href="https://www.linkedin.com/in/{{ site.data.socials.linkedin_username }}"
            title="LinkedIn"
            rel="external nofollow noopener"
            target="_blank"
            ><i class="fa-brands fa-linkedin"></i
          ></a>
        {% endif %}
        {% if cv_pdf %}
          <a href="{{ cv_pdf | relative_url }}" title="CV"><i class="ai ai-cv"></i></a>
        {% endif %}
      </div>
      <!-- Navbar Toggle -->
      <button
        class="navbar-toggler collapsed ml-auto"
        type="button"
        data-toggle="collapse"
        data-target="#navbarNav"
        aria-controls="navbarNav"
        aria-expanded="false"
        aria-label="Toggle navigation"
      >
        <span class="sr-only">Toggle navigation</span>
        <span class="icon-bar top-bar"></span>
        <span class="icon-bar middle-bar"></span>
        <span class="icon-bar bottom-bar"></span>
      </button>

      <div class="collapse navbar-collapse text-right" id="navbarNav">
        <ul class="navbar-nav ml-auto flex-nowrap">
          {% for candidate_page in site.pages %}
            {% if candidate_page.permalink == '/' %} {% assign about_title = candidate_page.title %} {% endif %}
          {% endfor %}
          {% assign about_label = about_title %}
          {% assign about_url = '/' %}
          {% if current_is_zh %}
            {% assign about_label = '关于' %}
            {% assign about_url = '/zh/' %}
          {% endif %}
          {% assign about_active = false %}
          {% if page.permalink == '/' or page.permalink == '/zh/' %}
            {% assign about_active = true %}
          {% endif %}

          <!-- About -->
          <li class="nav-item {% if about_active %}active{% endif %}">
            <a class="nav-link" href="{{ about_url | relative_url }}">
              {{- about_label }}
              {% if about_active %}
                <span class="sr-only">(current)</span>
              {% endif %}
            </a>
          </li>

          <!-- Other pages -->
          {% assign sorted_pages = site.pages | sort: 'nav_order' %}
          {% for p in sorted_pages %}
            {% if p.nav and p.autogen == null %}
              {% if p.dropdown %}
                {% assign has_active_child = false %}
                {% for child in p.children %}
                  {% if page.title == child.title %}
                    {% assign has_active_child = true %}
                  {% endif %}
                {% endfor %}
                <li class="nav-item dropdown {% if page.title == p.title or has_active_child %}active{% endif %}">
                  <a
                    class="nav-link dropdown-toggle"
                    href="#"
                    id="navbarDropdown"
                    role="button"
                    data-toggle="dropdown"
                    aria-haspopup="true"
                    aria-expanded="false"
                  >
                    {{- p.title }}
                    {% if page.title == p.title or has_active_child %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                  <div class="dropdown-menu dropdown-menu-right" aria-labelledby="navbarDropdown">
                    {% for child in p.children %}
                      {% if child.title == 'divider' %}
                        <div class="dropdown-divider"></div>
                      {% else %}
                        <a
                          class="dropdown-item {% if page.title == child.title %}active{% endif %}"
                          href="{% if child.permalink contains '://' %}{{ child.permalink }}{% else %}{{ child.permalink | relative_url }}{% endif %}"
                        >
                          {{- child.title -}}
                        </a>
                      {% endif %}
                    {% endfor %}
                  </div>
                </li>
              {% else %}
                {% assign parent_link = p.permalink | remove: 'index.html' %}
                {% assign nav_title = p.title %}
                {% assign nav_item_active = false %}
                {% if page.url contains parent_link %}
                  {% assign nav_item_active = true %}
                {% endif %}
                {%- if p.permalink contains '://' -%}
                  {%- assign url = p.permalink -%}
                {%- elsif p.permalink contains '/blog/' -%}
                  {%- assign url = '/blog/' -%}
                {%- else -%}
                  {%- assign url = p.url -%}
                {%- endif %}
                {% if current_is_zh and p.title == 'Blog' %}
                  {% assign nav_title = '博客' %}
                  {% assign url = '/zh/blog/' %}
                  {% if page.url contains '/zh/blog/' %}
                    {% assign nav_item_active = true %}
                  {% endif %}
                {% endif %}
                <li class="nav-item {% if nav_item_active %}active{% endif %}">
                  <a class="nav-link" href="{{ url | relative_url }}">
                    {{- nav_title }}
                    {% if nav_item_active %}
                      <span class="sr-only">(current)</span>
                    {% endif %}
                  </a>
                </li>
              {% endif %}
            {% endif %}
          {% endfor %}
          {% assign lang_en_url = page.lang_en_url | default: '/' %}
          {% assign lang_zh_url = page.lang_zh_url | default: '/zh/' %}
          {% if current_is_zh %}
            {% assign lang_switch_url = lang_en_url %}
            {% assign lang_switch_label = 'EN' %}
            {% assign lang_switch_title = 'Switch to English' %}
          {% else %}
            {% assign lang_switch_url = lang_zh_url %}
            {% assign lang_switch_label = '中' %}
            {% assign lang_switch_title = '切换到中文' %}
          {% endif %}
          <li class="nav-item language-switcher {% if current_is_zh %}is-zh{% else %}is-en{% endif %}">
            <a
              class="nav-link language-switch-button"
              href="{{ lang_switch_url | relative_url }}"
              title="{{ lang_switch_title }}"
              aria-label="{{ lang_switch_title }}"
            >
              <span>{{ lang_switch_label }}</span>
            </a>
          </li>
          {% if site.search_enabled %}
            <!-- Search -->
            <li class="nav-item">
              <button id="search-toggle" title="Search" onclick="openSearchModal()">
                <span class="nav-link">ctrl k <i class="ti ti-search"></i></span>
              </button>
            </li>
          {% endif %}
          {% if site.enable_darkmode %}
            <!-- Toogle theme mode -->
            <li class="toggle-container">
              <button id="light-toggle" title="Change theme">
                <i class="ti ti-sun-moon" id="light-toggle-system"></i>
                <i class="ti ti-moon-filled" id="light-toggle-dark"></i>
                <i class="ti ti-sun-filled" id="light-toggle-light"></i>
              </button>
            </li>
          {% endif %}
        </ul>
      </div>
    </div>
  </nav>
  {% if site.enable_progressbar %}
    <!-- Scrolling Progress Bar -->
    <progress id="progress" value="0">
      <div class="progress-container">
        <span class="progress-bar"></span>
      </div>
    </progress>
  {% endif %}
</header>
